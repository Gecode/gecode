@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
if("@GECODE_PACKAGE_NEEDS_THREADS@" STREQUAL "ON")
  find_dependency(Threads)
endif()
if("@GECODE_PACKAGE_NEEDS_MPFR@" STREQUAL "ON")
  set(_gecode_mpfr_args)
  if(Gecode_FIND_QUIETLY)
    list(APPEND _gecode_mpfr_args QUIET)
  endif()
  if(NOT TARGET MPFR::MPFR)
    find_package(MPFR QUIET CONFIG)
  endif()
  if(NOT TARGET MPFR::MPFR)
    set(_gecode_had_mpfr_root FALSE)
    if(DEFINED MPFR_ROOT)
      set(_gecode_had_mpfr_root TRUE)
      set(_gecode_saved_mpfr_root "${MPFR_ROOT}")
    endif()
    set(_gecode_had_gmp_root FALSE)
    if(DEFINED GMP_ROOT)
      set(_gecode_had_gmp_root TRUE)
      set(_gecode_saved_gmp_root "${GMP_ROOT}")
    endif()
    if(NOT DEFINED MPFR_ROOT)
      set(_gecode_vcpkg_mpfr_root)
      if(DEFINED VCPKG_INSTALLED_DIR AND DEFINED VCPKG_TARGET_TRIPLET)
        file(TO_CMAKE_PATH "${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}" _gecode_vcpkg_mpfr_root)
      elseif(DEFINED ENV{VCPKG_ROOT} AND DEFINED VCPKG_TARGET_TRIPLET)
        file(TO_CMAKE_PATH "$ENV{VCPKG_ROOT}/installed/${VCPKG_TARGET_TRIPLET}" _gecode_vcpkg_mpfr_root)
      endif()
      if(NOT "${_gecode_vcpkg_mpfr_root}" STREQUAL "" AND EXISTS "${_gecode_vcpkg_mpfr_root}")
        set(MPFR_ROOT "${_gecode_vcpkg_mpfr_root}")
        if(NOT DEFINED GMP_ROOT)
          set(GMP_ROOT "${_gecode_vcpkg_mpfr_root}")
        endif()
      endif()
      unset(_gecode_vcpkg_mpfr_root)
    endif()
    set(_gecode_saved_module_path "${CMAKE_MODULE_PATH}")
    list(PREPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")
    find_package(MPFR ${_gecode_mpfr_args} MODULE)
    set(CMAKE_MODULE_PATH "${_gecode_saved_module_path}")
    unset(_gecode_saved_module_path)
    if(_gecode_had_mpfr_root)
      set(MPFR_ROOT "${_gecode_saved_mpfr_root}")
    else()
      unset(MPFR_ROOT)
    endif()
    if(_gecode_had_gmp_root)
      set(GMP_ROOT "${_gecode_saved_gmp_root}")
    else()
      unset(GMP_ROOT)
    endif()
    unset(_gecode_had_gmp_root)
    unset(_gecode_had_mpfr_root)
    unset(_gecode_saved_gmp_root)
    unset(_gecode_saved_mpfr_root)
  endif()
  unset(_gecode_mpfr_args)
  if(NOT TARGET MPFR::MPFR)
    set(Gecode_FOUND FALSE)
    set(Gecode_NOT_FOUND_MESSAGE "Gecode was built with MPFR support, but the MPFR::MPFR target was not found")
    return()
  endif()
endif()
set(_gecode_qt_components "@GECODE_PACKAGE_QT_COMPONENTS@")
set(_gecode_qt_version "@GECODE_PACKAGE_QT_VERSION@")
if("@GECODE_PACKAGE_QT_MAJOR@" STREQUAL "6")
  find_dependency(Qt6 ${_gecode_qt_version} COMPONENTS ${_gecode_qt_components})
elseif("@GECODE_PACKAGE_QT_MAJOR@" STREQUAL "5")
  find_dependency(Qt5 ${_gecode_qt_version} COMPONENTS ${_gecode_qt_components})
endif()
unset(_gecode_qt_version)

include("${CMAKE_CURRENT_LIST_DIR}/GecodeTargets.cmake")

set(Gecode_VERSION "@GECODE_PROJECT_VERSION@")
set_and_check(Gecode_INCLUDE_DIRS "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")
set(Gecode_LIBRARIES Gecode::gecode)

set(_gecode_supported_components
  support
  kernel
  search
  int
  set
  float
  minimodel
  driver
  flatzinc
  gist)

foreach(_gecode_component IN LISTS _gecode_supported_components)
  set(_gecode_component_target "Gecode::gecode${_gecode_component}")
  if(TARGET ${_gecode_component_target})
    set(_gecode_component_found TRUE)
  else()
    set(_gecode_component_found FALSE)
  endif()
  set(Gecode_${_gecode_component}_FOUND ${_gecode_component_found})
  set(Gecode_gecode${_gecode_component}_FOUND ${_gecode_component_found})
endforeach()

foreach(_gecode_requested_component IN LISTS Gecode_FIND_COMPONENTS)
  if(NOT DEFINED Gecode_${_gecode_requested_component}_FOUND)
    set(Gecode_${_gecode_requested_component}_FOUND FALSE)
  endif()
endforeach()

unset(_gecode_component)
unset(_gecode_component_found)
unset(_gecode_component_target)
unset(_gecode_requested_component)
unset(_gecode_supported_components)

check_required_components(Gecode)
